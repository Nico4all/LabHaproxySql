service mysqlchk
{
    type            = UNLISTED
    disable         = no
    socket_type     = stream
    protocol        = tcp
    port            = 9200
    wait            = no
    user            = root
    server          = /usr/local/bin/healthcheck.sh
    log_on_failure  += USERID
    per_source      = UNLIMITED
    cps             = 100 2
}